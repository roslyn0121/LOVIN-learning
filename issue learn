<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>LOVIN | 80週年旗艦銷售百科</title>
    <style>
        :root {
            --milk-cream: #FBF2E2;   
            --soft-yellow: #FFEFD7; 
            --soft-peach: #F6DDCE; 
            --sage-green: #BBB2A2;   
            --deep-sage: #8A9A8E;    
            --gold: #B8975A;         
            --white: #FFFFFF;        
            --accent-red: #D32F2F;   
        }

        body {
            font-family: "PingFang TC", "STHeiti", "Microsoft JhengHei", sans-serif;
            background-color: var(--milk-cream);
            color: var(--deep-sage);
            margin: 0; padding: 0;
            line-height: 1.6;
        }

        header {
            background: var(--white);
            padding: 25px 20px;
            text-align: center;
            border-bottom: 4px solid var(--soft-peach);
            position: sticky; top: 0; z-index: 1000;
        }

        .brand-logo { font-size: 2.2rem; letter-spacing: 6px; margin: 0; font-weight: 900; color: var(--deep-sage); }
        .promo-tag { background: var(--gold); color: white; display: inline-block; padding: 2px 12px; border-radius: 50px; font-size: 0.8rem; margin-top: 8px; }

        nav {
            display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; padding: 12px;
        }

        nav button {
            padding: 10px 5px; border: 1.5px solid var(--sage-green); background: var(--white);
            color: var(--sage-green); border-radius: 10px; font-weight: bold; cursor: pointer; transition: 0.3s;
            font-size: 0.85rem;
            outline: none;
        }

        nav button.active { background: var(--deep-sage); color: var(--white); border-color: var(--deep-sage); }

        .container { padding: 0 15px 40px; max-width: 600px; margin: auto; }
        .section { display: none; animation: fadeIn 0.4s; }
        .section.active { display: block; }

        @keyframes fadeIn { from {opacity: 0;} to {opacity: 1;} }

        .card {
            background: var(--white); border-radius: 20px; padding: 25px;
            margin-bottom: 25px; box-shadow: 0 8px 20px rgba(187, 178, 162, 0.15);
        }

        h2 { color: var(--gold); border-left: 5px solid var(--soft-peach); padding-left: 15px; margin-top: 0; font-size: 1.3rem; }
        h3 { color: var(--deep-sage); font-size: 1.1rem; margin-top: 20px; border-bottom: 1px solid var(--soft-peach); display: inline-block; }
        
        .qa-item { margin-bottom: 20px; border-bottom: 1px solid var(--milk-cream); padding-bottom: 15px; }
        .qa-q { color: var(--gold); font-weight: bold; font-size: 1.05rem; display: block; margin-bottom: 5px; }
        .qa-fact { font-size: 0.8rem; color: #999; margin-bottom: 8px; font-style: italic; }
        .qa-a { color: var(--deep-sage); background: var(--soft-yellow); padding: 10px 15px; border-radius: 10px; display: block; }
        .qa-a div { margin-bottom: 4px; border-left: 2px solid var(--gold); padding-left: 8px; }

        .power-item { background: var(--soft-yellow); padding: 15px; border-radius: 12px; margin-bottom: 15px; border-left: 4px solid var(--gold); }
        .highlight { color: var(--accent-red); font-weight: bold; }
